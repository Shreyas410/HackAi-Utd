# Personalised Learning System Configuration
# Copy this file to .env and update values as needed

# ============== REQUIRED FOR PRODUCTION ==============
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
# Without this key, the system uses mock responses (for testing only)
GEMINI_API_KEY=your_gemini_api_key_here

# ============== APPLICATION SETTINGS ==============
DEBUG=false
APP_NAME="Personalised Learning System"

# Database (default: SQLite)
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/learning_db
DATABASE_URL=sqlite+aiosqlite:///./learning_system.db

# Session settings
SESSION_EXPIRY_HOURS=24

# ============== QUIZ SETTINGS ==============
MIN_QUIZ_QUESTIONS=5
MAX_QUIZ_QUESTIONS=10

# Quiz score thresholds for level adjustment
UPGRADE_SCORE_THRESHOLD=0.85
DOWNGRADE_SCORE_THRESHOLD=0.4

# ============== CLASSIFICATION ==============
# These thresholds are only used by the MockGeminiClient for testing
# In production, Gemini performs classification without local thresholds
BEGINNER_THRESHOLD=2.5
INTERMEDIATE_THRESHOLD=4.0
